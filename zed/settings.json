// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git_panel": {
    "tree_view": true,
  },
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "settings": {
        "github_personal_access_token": ""
      },
    },
  },
  "agent_servers": {
    "codex": {
      "default_mode": "auto",
      "favorite_models": [
        "gpt-5.2-codex/medium",
        "gpt-5.2/medium",
        "gpt-5.3-codex/medium"
      ],
      "default_model": "gpt-5.3-codex/medium",
    },
  },
  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "lsp_pull_diagnostics": {
      "enabled": true,
      "debounce_ms": 50,
    },
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0,
      "max_severity": null,
    },
    // "cargo": null
  },

  "languages": {
    "Markdown": {
      "show_edit_predictions": true,
    },
    "JSON": {
      "show_edit_predictions": true,
    },
    "HTML": {
      "show_edit_predictions": true,
      "formatter": "language_server",
      "format_on_save": "off",
    },
    "SCSS": {
      "show_edit_predictions": true,
      "enable_language_server": true,
    },
    "CSS": {
      "show_edit_predictions": true,
      "enable_language_server": true,
      // "language_servers": ["css"],
      "show_completions_on_input": true,
    },
    "JavaScript": {
      "show_edit_predictions": true,
      // "language_servers": ["vtsls"],
    },
    "TSX": {
      "show_edit_predictions": true,
      // "language_servers": ["vtsls"],
    },
    "TypeScript": {
      "show_edit_predictions": true,
      "language_servers": ["!vtsls", "typescript-language-server"],
    },
    "Vue.js": {
      "format_on_save": "on",
      "formatter": "language_server",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true,
      },
    },
  },
  "show_edit_predictions": true,
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
    "enabled_in_text_threads": false,
  },
  "agent": {
    "default_profile": "ask",
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
    },
    "enabled": true,
    "single_file_review": false,
    "model_parameters": [],
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
  },
  "icon_theme": "Material Icon Theme",
  "vim_mode": true,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "buffer_line_height": { "custom": 1.3 },
  "theme": {
    "mode": "dark",
    "light": "Tokyo Night Light",
    "dark": "Kanagawa Dragon",
  },
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "on_yank",
  },

  "lsp": {
    "vtsls": {
      "settings": {
        // "vtsls": {
        //   "experimental": {
        //     "completion": {
        //       "enableServerSideFuzzyMatch": false,
        //       "entriesLimit": 2000,
        //     },
        //   },
        // },
        // "trace": "verbose",
        // "tsserver": {
        //   "globalPlugins": [
        //     {
        //       "name": "@vue/typescript-plugin",
        //       "location": "/home/fourhl/.local/share/zed/extensions/work/vue",
        //       "languages": ["vue.js"],
        //       "enableForWorkspaceTypeScriptVersions": true,
        //       "configNamespace": "typescript",
        //     },
        //   ],
        // },
        // "typescript": {
        //   "updateImportsOnFileMove": { "enabled": "always" },// "preferences": {//   "includeCompletionsForModuleExports": true,//   "includeCompletionsWithInsertText": true,//   "includeCompletionsWithSnippetText": true,//   "includeCompletionsForInternalSymbolExports": true,//   "includePackageJsonAutoImports": "auto",//   "includeCompletionsForImportStatements": true,//   "includeCompletionsForJSDocTags": true,//   "includeCompletionsForClassMembers": true,//   "includeInlayParameterNameHints": "none",//   "includeCompletionsForDerivedTypes": false,// },// <‑ key line: do not include DOM libs in completions
        // },
        // "javascript": {
        //   "updateImportsOnFileMove": { "enabled": "always" },// "lib": [],
        // },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true,
    },
    "vscode-html-language-server": {
      "settings": {
        "html": {
          "format": {
            // Indent under <html> and <head> (default: false)
            "indentInnerHtml": true,
            // Disable formatting inside <svg> or <script>
            "contentUnformatted": "svg,script",
            // Add an extra newline before <div> and <p>
            "extraLiners": "div,p",
          },
        },
      },
    },
    // "vscode-css-language-server": {
    //   "settings": {
    //     "css": { "lint": { "unknownAtRules": "ignore" } },
    //     "scss": { "lint": { "unknownAtRules": "ignore" } },
    //     "less": { "lint": { "unknownAtRules": "ignore" } },
    //   },
    // },
  },
}
